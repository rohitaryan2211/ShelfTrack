# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ─── Ingest scripts only (never expose to the browser) ────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY

# ─── Google Books API (optional — used to enrich volumes with ISBN-13) ────────
# Get a free key at: https://console.cloud.google.com/apis/library/books.googleapis.com
# No credit card required for the free quota (~1000 req/day)
GOOGLE_BOOKS_API_KEY=YOUR_GOOGLE_BOOKS_KEY
